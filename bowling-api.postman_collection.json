    {
      "name": "Auth",
      "item": [

        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('JWT saved to collection variable \"token\"');",
                  "    pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "    pm.test('Token received', () => {",
                  "        pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "    });",
                  "    pm.test('Username returned', () => {",
                  "        pm.expect(json.username).to.be.a('string');",
                  "    });",
                  "    pm.test('Roles returned', () => {",
                  "        pm.expect(json.roles).to.be.an('array').and.not.empty;",
                  "    });",
                  "} else {",
                  "    pm.test('Login failed - check credentials', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"changeme\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Obtain a JWT token. No authentication required.\n\nThe test script automatically saves the token to the `token` collection variable so all subsequent requests are authenticated."
          }
        },

